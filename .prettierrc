{
  "printWidth": 100,
  "plugins": ["prettier-plugin-tailwindcss", "prettier-plugin-svelte"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    },
    {
      "files": "*.{svx,md}",
      "options": {
        "parser": "markdown",
        "proseWrap": "always"
      }
    }
  ],
  "tailwindStylesheet": "./src/app.css"
}
